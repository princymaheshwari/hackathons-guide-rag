# Copy this file to .env and replace the placeholder with your actual key.
# .env is listed in .gitignore — never commit your real key.
#
# Get a free Groq API key (no credit card required) at:
# https://console.groq.com

GROQ_API_KEY=your_key_here

# Optional: needed when Reddit blocks anonymous thread JSON requests.
# Create a Reddit app at https://www.reddit.com/prefs/apps and use the
# app's client id and secret here. Do not commit your real .env file.
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
